{
  "family": "mindspark-frontend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256", "memory": "512",
  "executionRoleArn": "arn:aws:iam::726412861887:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    { "name": "frontend",
      "image": "726412861887.dkr.ecr.us-east-1.amazonaws.com/mindspark/frontend:latest",
      "portMappings": [{"containerPort": 80, "protocol": "tcp"}],
      "essential": true }
  ]
}
