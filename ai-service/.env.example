# ════════════════════════════════════════════════════════════════
# AI Service (AI Service VPC) — salin jadi ".env":  cp .env.example .env
# ════════════════════════════════════════════════════════════════

# ── Database vektor (pgvector) — tabel "chunks" ─────────────────────
#   • Docker Compose  → host "db", port 5432
#   • Lokal (uvicorn) → host localhost, port 5433
DATABASE_URL=postgresql://mindspark:mindspark@db:5432/mindspark
# DATABASE_URL=postgresql://mindspark:mindspark@localhost:5433/mindspark

# ── Embedding self-hosted (bonus "Self-hosted AI Model" +5) ─────────
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
# true  = embedding mock deterministik → test lokal cepat TANPA download ~2 GB
# false = pakai bge-m3 sungguhan (untuk demo / cloud)
USE_MOCK_EMBEDDING=true

# ── Gemini (LLM untuk generation jawaban + ringkasan + quiz) ────────
# Dapatkan key GRATIS di Google AI Studio:
#   https://aistudio.google.com/app/apikey
# Kosongkan = mode mock (sistem tetap jalan, jawaban berupa placeholder).
GEMINI_API_KEY=
# Beberapa model dipisah koma → fallback otomatis saat satu model kena limit (429).
GEMINI_MODEL=gemini-2.5-flash-lite,gemini-2.0-flash-lite,gemini-2.5-flash,gemini-2.0-flash

# ── Retrieval ───────────────────────────────────────────────────────
TOP_K=6
