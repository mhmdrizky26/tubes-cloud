# ════════════════════════════════════════════════════════════════
# Backend API — salin file ini jadi ".env" lalu sesuaikan.
#   cp .env.example .env
# ════════════════════════════════════════════════════════════════

# ── Database (Database VPC) ─────────────────────────────────────────
# Pilih SALAH SATU sesuai cara menjalankan:
#   • Docker Compose  → host "db", port 5432 (default di bawah)
#   • Lokal (uvicorn) → host localhost, port 5433 (sesuai container test)
DATABASE_URL=postgresql+psycopg2://mindspark:mindspark@db:5432/mindspark
# DATABASE_URL=postgresql+psycopg2://mindspark:mindspark@localhost:5433/mindspark

# ── Auth ────────────────────────────────────────────────────────────
JWT_SECRET=ganti-dengan-string-acak-panjang
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── AI Service (AI Service VPC) ─────────────────────────────────────
#   • Docker Compose  → http://ai-service:8001
#   • Lokal           → http://localhost:8001
AI_SERVICE_URL=http://ai-service:8001
# AI_SERVICE_URL=http://localhost:8001

# ── Object Storage (Multi-Cloud: bucket GCP, compute AWS) ───────────
GCS_BUCKET=mindspark-materials
# Path ke service-account JSON di dalam container. Kosongkan untuk
# mode lokal → file upload disimpan ke disk (LOCAL_STORAGE_DIR).
GOOGLE_APPLICATION_CREDENTIALS=
LOCAL_STORAGE_DIR=./.uploads

# ── CORS — origin frontend yang diizinkan ───────────────────────────
#   • Docker (nginx) → http://localhost:8080
#   • Lokal (vite)   → http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173
