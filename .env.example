# ════════════════════════════════════════════════════════════════
# Variabel untuk docker-compose — salin jadi ".env":  cp .env.example .env
# (docker-compose otomatis membaca file .env di folder ini)
# ════════════════════════════════════════════════════════════════

# Gemini API key (dipakai AI Service untuk generation).
# Dapatkan GRATIS di Google AI Studio → https://aistudio.google.com/app/apikey
# Kosong = mode mock (sistem tetap jalan tanpa key).
GEMINI_API_KEY=

# Pakai bge-m3 asli (false) atau embedding mock cepat (true) saat docker up.
USE_MOCK_EMBEDDING=false

# Secret untuk JWT backend (ganti dengan string acak panjang).
JWT_SECRET=ganti-dengan-string-acak-panjang

# Multi-cloud bucket (Azure Blob Storage). Kosongkan = simpan lokal.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=materials

# URL backend yang dipakai frontend saat build (Docker → host port 8000).
VITE_API_URL=http://localhost:8000
# Origin frontend yang diizinkan CORS (Docker nginx → port 8080).
FRONTEND_ORIGIN=http://localhost:8080
